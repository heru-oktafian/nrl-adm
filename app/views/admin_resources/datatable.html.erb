<% content_for(:title, "#{@resource[:title]} — nrl-adm") %>

<div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
  <!-- Dark Sidebar -->
  <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
    <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
      <!-- Logo -->
      <div class="mb-8 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
          <span class="text-2xl font-bold text-sky-400">N</span>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">nrl-adm</p>
          <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="space-y-2">
        <% navigation_items.each do |item| %>
          <% active = active_nav_key == item[:key] %>
          <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
            <span><%= item[:label] %></span>
            <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
          <% end %>
        <% end %>
      </nav>

      <!-- Info Card -->
      <div class="mt-8 rounded-[24px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.3em] text-sky-200/70"><%= @resource[:title] %></p>
        <p class="mt-4 text-2xl font-semibold text-white">Data table mode</p>
        <p class="mt-2 text-sm leading-6 text-slate-300/90"><%= @resource[:summary] %></p>
      </div>

      <!-- Logout -->
      <div class="mt-auto pt-8">
        <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
    <div class="mx-auto max-w-7xl space-y-6">
      <!-- Header -->
      <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600"><%= @resource[:title] %></p>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Live <%= @resource[:title] %> records</h1>
            <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Kelola data <%= @resource[:title].downcase %> portfolio kamu.</p>
          </div>
          <% unless @resource_key == "contact-messages" %>
            <button type="button" onclick="openAddModal()" class="inline-flex items-center gap-2 rounded-2xl bg-sky-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-500/20 hover:bg-sky-600">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              Tambah
            </button>
          <% end %>
        </div>
      </header>

      <!-- Main Content Area -->
      <section class="grid gap-6 xl:grid-cols-[minmax(0,1.3fr)_320px]">
        <!-- Data Table Card -->
        <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.05)] sm:p-6">
          <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Data table</p>
              <h2 class="mt-2 text-2xl font-semibold text-slate-950">All Records</h2>
            </div>
            <div class="flex items-center gap-3">
              <span class="rounded-full px-3 py-1.5 text-xs font-medium <%= @data[:status] == :ok ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600' %>"><%= @data[:status].to_s.humanize %></span>
            </div>
          </div>

          <% if @data[:status] == :error %>
            <div class="mb-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-4 text-sm text-rose-700">
              <%= @data[:message] %>
            </div>
          <% end %>

          <div class="overflow-hidden rounded-[24px] border border-slate-200">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                  <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">#</th>
                    <% case @resource_key %>
                    <% when "projects" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Title</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Tech Stack</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">URL</th>
                    <% when "skills" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Name</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Category</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Level</th>
                    <% when "experiences" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Company</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Position</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Period</th>
                    <% when "social-links" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Platform</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">URL</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Icon</th>
                    <% when "tools" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Name</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Icon</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">URL</th>
                    <% when "contact-messages" %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Name</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Email</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Subject</th>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Status</th>
                    <% else %>
                      <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Data</th>
                    <% end %>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-[0.24em] text-slate-400 sm:px-5">Action</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                  <% if @items.present? %>
                    <% @items.each_with_index do |item, index| %>
                      <tr class="transition hover:bg-slate-50/80">
                        <td class="px-4 py-4 align-top text-slate-400 sm:px-5"><%= index + 1 %></td>
                        <% case @resource_key %>
                        <% when "projects" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">
                            <p class="font-medium"><%= item["title"] || "-" %></p>
                            <p class="mt-1 text-xs text-slate-400 line-clamp-2"><%= item["description"]&.truncate(80) || "-" %></p>
                          </td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["tech_stack"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">
                            <% if item["url"].present? %>
                              <a href="<%= item["url"] %>" target="_blank" class="text-sky-600 hover:underline">Link ↗</a>
                            <% else %>
                              -
                            <% end %>
                          </td>
                        <% when "skills" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 font-medium"><%= item["name"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["category"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">
                            <div class="flex items-center gap-2">
                              <div class="h-2 w-24 rounded-full bg-slate-200">
                                <div class="h-2 rounded-full bg-sky-500" style="width: <%= item["level"] || 0 %>%"></div>
                              </div>
                              <span class="text-xs text-slate-500"><%= item["level"] || 0 %></span>
                            </div>
                          </td>
                        <% when "experiences" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 font-medium"><%= item["company"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["position"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 text-sm"><%= item["start_date"] %> → <%= item["end_date"] || "Present" %></td>
                        <% when "social-links" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 font-medium"><%= item["platform"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">
                            <% if item["url"].present? %>
                              <a href="<%= item["url"] %>" target="_blank" class="text-sky-600 hover:underline truncate block max-w-[200px]"><%= item["url"] %></a>
                            <% else %>
                              -
                            <% end %>
                          </td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["icon"] || "-" %></td>
                        <% when "tools" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 font-medium"><%= item["name"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["icon"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">
                            <% if item["url"].present? %>
                              <a href="<%= item["url"] %>" target="_blank" class="text-sky-600 hover:underline">Link ↗</a>
                            <% else %>
                              -
                            <% end %>
                          </td>
                        <% when "contact-messages" %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5 font-medium"><%= item["name"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["email"] || "-" %></td>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5"><%= item["subject"] || "-" %></td>
                          <td class="px-4 py-4 align-top sm:px-5">
                            <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-medium <%= item["status"] == 'done' ? 'bg-emerald-50 text-emerald-600' : item["status"] == 'in_progress' ? 'bg-amber-50 text-amber-600' : 'bg-sky-50 text-sky-600' %>">
                              <%= item["status"] || "new" %>
                            </span>
                          </td>
                        <% else %>
                          <td class="px-4 py-4 align-top text-slate-700 sm:px-5">-</td>
                        <% end %>
                        <td class="px-4 py-4 align-top sm:px-5">
                          <% if @resource_key == "contact-messages" %>
                            <button type="button" onclick="showMessage('<%= item.to_json.gsub("'", "\\\\'") %>')" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Detail</button>
                          <% else %>
                            <div class="flex flex-wrap gap-2">
                              <button type="button" onclick="editItem('<%= item.to_json.gsub("'", "\\\\'") %>')" class="inline-flex rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">Edit</button>
                              <button type="button" onclick="deleteItem('<%= item["id"] %>', '<%= item["title"] || item["name"] || item["platform"] || item["company"] %>')" class="inline-flex rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-600">Delete</button>
                            </div>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  <% else %>
                    <tr>
                      <td colspan="5" class="px-4 py-8 text-center text-sm text-slate-500 sm:px-5">Belum ada data untuk modul ini.</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Endpoint</p>
            <div class="mt-5 rounded-2xl bg-slate-50 px-4 py-4 text-sm text-slate-700">
              <code class="break-all">/api/v1<%= @resource[:endpoint] %></code>
            </div>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Total Records</p>
            <p class="mt-5 text-4xl font-bold text-slate-950"><%= @items.count %></p>
          </div>

          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Quick Info</p>
            <div class="mt-5 space-y-3 text-sm text-slate-600">
              <div class="rounded-2xl bg-slate-50 px-4 py-3">Gunakan panel ini untuk CRUD data <%= @resource[:title].downcase %>.</div>
              <div class="rounded-2xl bg-slate-50 px-4 py-3">Data tersimpan di database PostgreSQL via nrl-be API.</div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>
</div>

<!-- Add Modal -->
<div id="add-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
  <div class="w-full max-w-2xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
    <div class="mb-5 flex items-center justify-between gap-4">
      <h3 class="text-2xl font-semibold text-slate-950">Tambah <%= @resource[:title] %></h3>
      <button type="button" onclick="closeAddModal()" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
    </div>
    <form id="add-form" method="POST" action="/admin/<%= @resource_key %>">
      
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      
      <div id="add-form-fields" class="space-y-4">
        <!-- Dynamic fields will be inserted here -->
      </div>
      
      <div class="mt-6 flex flex-wrap gap-3">
        <button type="submit" class="rounded-2xl bg-sky-500 px-5 py-3 text-sm font-semibold text-white hover:bg-sky-600">Simpan</button>
        <button type="button" onclick="closeAddModal()" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Batal</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
  <div class="w-full max-w-2xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
    <div class="mb-5 flex items-center justify-between gap-4">
      <h3 id="modal-title" class="text-2xl font-semibold text-slate-950">Edit</h3>
      <button type="button" onclick="closeModal()" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
    </div>
    <form id="edit-form" method="POST">
      <input type="hidden" name="_method" value="PUT">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      <input type="hidden" id="edit-id" name="id">
      
      <div id="form-fields" class="space-y-4">
        <!-- Dynamic fields will be inserted here -->
      </div>
      
      <div class="mt-6 flex flex-wrap gap-3">
        <button type="submit" class="rounded-2xl bg-slate-950 px-5 py-3 text-sm font-medium text-white hover:bg-sky-600">Update</button>
        <button type="button" onclick="closeModal()" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Batal</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
  <div class="w-full max-w-lg rounded-[28px] bg-white p-6 shadow-2xl">
    <h3 class="text-2xl font-semibold text-slate-950">Hapus Data</h3>
    <p id="delete-text" class="mt-4 text-sm leading-7 text-slate-600">Apakah anda yakin akan menghapus item ini?</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <form id="delete-form" method="POST">
        <input type="hidden" name="_method" value="DELETE">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-medium text-white">Ya, hapus</button>
      </form>
      <button type="button" onclick="closeDeleteModal()" class="rounded-2xl border border-slate-200 px-5 py-3 text-sm font-medium text-slate-700">Tidak</button>
    </div>
  </div>
</div>

<!-- Message Detail Modal -->
<div id="message-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-950/50 px-4">
  <div class="w-full max-w-3xl rounded-[28px] bg-white p-5 shadow-2xl sm:p-6">
    <div class="mb-5 flex items-center justify-between gap-4">
      <h3 class="text-2xl font-semibold text-slate-950">Message Detail</h3>
      <button type="button" onclick="closeMessageModal()" class="rounded-2xl border border-slate-200 px-3 py-2 text-sm text-slate-600">Close</button>
    </div>
    <div id="message-content" class="space-y-4">
      <!-- Message content will be inserted here -->
    </div>
  </div>
</div>

<script>
function getAddFields(resourceKey) {
  switch(resourceKey) {
    case 'projects':
      return `
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Title <span class="text-rose-500">*</span></label>
            <input type="text" name="title" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Project title">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Tech Stack</label>
            <input type="text" name="tech_stack" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Ruby, Rails, React...">
          </div>
          <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>
            <textarea name="description" rows="3" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Project description..."></textarea>
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Image URL</label>
            <input type="text" name="image_url" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="https://...">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">URL</label>
            <input type="text" name="url" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="https://...">
          </div>
        </div>
      `;
    case 'skills':
      return `
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Name <span class="text-rose-500">*</span></label>
            <input type="text" name="name" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Skill name">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Category</label>
            <select name="category" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
              <option value="development">Development</option>
              <option value="design">Design</option>
              <option value="tools">Tools</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Level (0-100)</label>
            <input type="number" name="level" value="50" min="0" max="100" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
          </div>
        </div>
      `;
    case 'experiences':
      return `
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Company <span class="text-rose-500">*</span></label>
            <input type="text" name="company" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Company name">
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">Position <span class="text-rose-500">*</span></label>
            <input type="text" name="position" required class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" placeholder="Job title">
          </div>
          <div>

          <div>
            <label class="mb-2 block text-sm font-medium text-slate-700">End Date</label>
            <input type="text" name="end_date" value="${item.end_date || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
          </div>
          <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>

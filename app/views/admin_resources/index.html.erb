<% if @resource_key == "profile" %>
  <%# Profile Page %>
  <% content_for(:title, "Profile — nrl-adm") %>
  <div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
    <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
      <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
        <div class="mb-8 flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
            <span class="text-2xl font-bold text-sky-400">N</span>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">nrl-adm</p>
            <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
          </div>
        </div>

        <nav class="space-y-2">
          <% navigation_items.each do |item| %>
            <% active = active_nav_key == item[:key] %>
            <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
              <span><%= item[:label] %></span>
              <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
            <% end %>
          <% end %>
        </nav>

        <div class="mt-auto pt-8">
          <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
        </div>
      </div>
    </aside>

    <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
      <div class="mx-auto max-w-4xl space-y-6">
        <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
          <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Profile</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Edit Profile</h1>
          <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Kelola informasi profil dan identitas utama portfolio kamu.</p>
        </header>

        <% if @data[:items].present? %>
          <% profile = @data[:items].first %>
          <div class="rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.05)] sm:p-6">
            <%= form_with url: "/admin/profile", method: :put, class: "space-y-6" do |form| %>
              <div class="grid gap-5 md:grid-cols-2">
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
                  <%= form.text_field "profile[name]", value: profile["name"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Title</label>
                  <%= form.text_field "profile[title]", value: profile["title"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Email</label>
                  <%= form.email_field "profile[email]", value: profile["email"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Phone</label>
                  <%= form.text_field "profile[phone]", value: profile["phone"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Location</label>
                  <%= form.text_field "profile[location]", value: profile["location"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div>
                  <label class="mb-2 block text-sm font-medium text-slate-700">Image URL</label>
                  <%= form.text_field "profile[image_url]", value: profile["image_url"] || "", class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">Bio</label>
                  <%= form.text_area "profile[bio]", value: profile["bio"] || "", rows: 3, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
                <div class="md:col-span-2">
                  <label class="mb-2 block text-sm font-medium text-slate-700">About</label>
                  <%= form.text_area "profile[about]", value: profile["about"] || "", rows: 5, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm" %>
                </div>
              </div>

              <div class="flex flex-wrap gap-3 pt-4">
                <button type="submit" class="rounded-2xl bg-slate-950 px-6 py-3 text-sm font-medium text-white hover:bg-sky-600">Save Changes</button>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.05)]">
            <p class="text-slate-500">Profile data not found.</p>
          </div>
        <% end %>
      </div>
    </main>
  </div>
<% else %>
  <%# Render datatable for other resources %>
  <%= render template: "admin_resources/datatable" %>
<% end %>
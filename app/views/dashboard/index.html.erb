<% content_for(:title, "Dashboard — nrl-adm") %>

<div class="min-h-screen bg-slate-100 text-slate-900 lg:flex">
  <!-- Dark Sidebar -->
  <aside class="relative overflow-hidden bg-slate-950 text-white lg:w-72 xl:w-80">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(56,189,248,0.18),_transparent_48%)]"></div>
    <div class="relative flex h-full flex-col px-5 py-6 sm:px-6 lg:px-6 xl:px-8">
      <!-- Logo -->
      <div class="mb-8 flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-sky-500/20 p-2 ring-1 ring-white/10 shadow-[0_8px_20px_rgba(14,165,233,0.18)]">
          <span class="text-2xl font-bold text-sky-400">N</span>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-200/70">nrl-adm</p>
          <p class="mt-1 text-sm text-slate-300">Portfolio control panel</p>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="space-y-2">
        <% navigation_items.each do |item| %>
          <% active = item[:key] == "dashboard" %>
          <%= link_to item[:path], class: "flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-medium transition #{active ? 'bg-sky-500 text-slate-950 shadow-lg shadow-sky-500/20' : 'text-slate-300 hover:bg-white/5 hover:text-white'}" do %>
            <span><%= item[:label] %></span>
            <span class="h-2 w-2 rounded-full <%= active ? 'bg-slate-950/80' : 'bg-slate-600' %>"></span>
          <% end %>
        <% end %>
      </nav>

      <!-- Info Card -->
      <div class="mt-8 rounded-[24px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.3em] text-sky-200/70">Stats</p>
        <p class="mt-4 text-2xl font-semibold text-white">Overview</p>
        <p class="mt-2 text-sm leading-6 text-slate-300/90">Kelola portfolio dengan mudah melalui panel admin ini.</p>
      </div>

      <!-- Logout -->
      <div class="mt-auto pt-8">
        <%= button_to "Logout", logout_path, method: :delete, class: "w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-medium text-white transition hover:bg-white/10" %>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8 xl:px-10">
    <div class="mx-auto max-w-7xl space-y-6">
      <!-- Header -->
      <header class="rounded-[28px] border border-slate-200 bg-white px-5 py-5 shadow-[0_20px_60px_rgba(15,23,42,0.06)] sm:px-6 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">Dashboard</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">Selamat datang, Admin!</h1>
        <p class="mt-3 text-sm leading-7 text-slate-500 sm:text-base">Kelola semua konten portfolio dari satu tempat.</p>
      </header>

      <!-- Stats Cards -->
      <section class="grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        <div class="group rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(15,23,42,0.1)] sm:p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Projects</p>
              <p class="mt-3 text-4xl font-bold text-slate-950"><%= @stats[:projects] %></p>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-sky-50 text-sky-500">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
            </div>
          </div>
          <div class="mt-4">
            <%= link_to "Kelola Projects", "/admin/projects", class: "text-sm font-medium text-sky-600 hover:text-sky-700" %>
          </div>
        </div>

        <div class="group rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(15,23,42,0.1)] sm:p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Skills</p>
              <p class="mt-3 text-4xl font-bold text-slate-950"><%= @stats[:skills] %></p>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-500">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
          </div>
          <div class="mt-4">
            <%= link_to "Kelola Skills", "/admin/skills", class: "text-sm font-medium text-sky-600 hover:text-sky-700" %>
          </div>
        </div>

        <div class="group rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(15,23,42,0.1)] sm:p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Experiences</p>
              <p class="mt-3 text-4xl font-bold text-slate-950"><%= @stats[:experiences] %></p>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-violet-50 text-violet-500">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
          </div>
          <div class="mt-4">
            <%= link_to "Kelola Experiences", "/admin/experiences", class: "text-sm font-medium text-sky-600 hover:text-sky-700" %>
          </div>
        </div>

        <div class="group rounded-[28px] border border-slate-200 bg-white p-5 shadow-[0_20px_60px_rgba(15,23,42,0.04)] transition hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(15,23,42,0.1)] sm:p-6">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-500">Messages</p>
              <p class="mt-3 text-4xl font-bold text-slate-950"><%= @stats[:messages] %></p>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-50 text-amber-500">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
          </div>
          <div class="mt-4">
            <%= link_to "Lihat Messages", "/admin/contact-messages", class: "text-sm font-medium text-sky-600 hover:text-sky-700" %>
          </div>
        </div>
      </section>

      <!-- Quick Links -->
      <section class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.04)]">
          <h3 class="text-lg font-semibold text-slate-950">Social Links</h3>
          <p class="mt-2 text-sm text-slate-500">Kelola link sosial media dan platform.</p>
          <%= link_to "Kelola Social Links →", "/admin/social-links", class: "mt-4 inline-block text-sm font-medium text-sky-600 hover:text-sky-700" %>
        </div>

        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.04)]">
          <h3 class="text-lg font-semibold text-slate-950">Tools</h3>
          <p class="mt-2 text-sm text-slate-500">Kelola tools dan teknologi yang digunakan.</p>
          <%= link_to "Kelola Tools →", "/admin/tools", class: "mt-4 inline-block text-sm font-medium text-sky-600 hover:text-sky-700" %>
        </div>

        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_20px_60px_rgba(15,23,42,0.04)]">
          <h3 class="text-lg font-semibold text-slate-950">Profile</h3>
          <p class="mt-2 text-sm text-slate-500">Edit informasi profil dan bio.</p>
          <%= link_to "Edit Profile →", "/admin/profile", class: "mt-4 inline-block text-sm font-medium text-sky-600 hover:text-sky-700" %>
        </div>
      </section>
    </div>
  </main>
</div>
<div class="min-h-screen bg-slate-100 text-slate-900">
  <div class="grid min-h-screen lg:grid-cols-[minmax(0,1fr)_minmax(420px,48%)]">
    <section class="flex items-center justify-center px-6 py-10 sm:px-10 lg:px-16 xl:px-24">
      <div class="w-full max-w-xl">
        <div class="mb-10">
          <p class="text-sm font-semibold uppercase tracking-[0.35em] text-sky-600">nrl-adm</p>
          <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl">Welcome back</h1>
          <p class="mt-4 max-w-lg text-sm leading-7 text-slate-500 sm:text-base">
            Sign in untuk mengelola profile, projects, skills, experiences, dan social links dari portfolio kamu.
          </p>
        </div>

        <% if flash[:notice].present? %>
          <div class="mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-700 shadow-sm">
            <%= flash[:notice] %>
          </div>
        <% end %>

        <% if flash.now[:alert].present? %>
          <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-4 text-sm text-rose-700 shadow-sm">
            <%= flash.now[:alert] %>
          </div>
        <% end %>

        <div class="rounded-[28px] border border-slate-200 bg-white p-6 shadow-[0_30px_80px_rgba(15,23,42,0.08)] sm:p-8">
          <%= form_with url: create_session_path, method: :post, class: "space-y-6" do |form| %>
            <div>
              <%= form.label :username, class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= form.text_field :username, required: true, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-slate-900 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100", placeholder: "admin" %>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between gap-3">
                <%= form.label :password, class: "block text-sm font-medium text-slate-700" %>
                <span class="text-xs font-medium text-slate-400">Secure access</span>
              </div>
              <%= form.password_field :password, required: true, class: "w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-slate-900 outline-none transition focus:border-sky-500 focus:bg-white focus:ring-4 focus:ring-sky-100", placeholder: "••••••••" %>
            </div>

            <%= form.submit "Login to dashboard", class: "w-full rounded-2xl bg-slate-950 px-4 py-3.5 text-sm font-semibold text-white transition hover:bg-sky-600 focus:outline-none focus:ring-4 focus:ring-sky-200" %>
          <% end %>
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-3 text-xs text-slate-400 sm:text-sm">
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5">JWT Cookie Session</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5">API Connected</span>
          <span class="rounded-full border border-slate-200 bg-white px-3 py-1.5">Responsive Layout</span>
        </div>
      </div>
    </section>

    <section class="relative hidden overflow-hidden bg-[radial-gradient(circle_at_top,_rgba(96,165,250,0.28),_rgba(37,99,235,0.96)_42%,_rgba(15,23,42,1)_100%)] lg:flex">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.07)_1px,transparent_1px)] bg-[size:42px_42px] opacity-30"></div>
      <div class="absolute -right-24 top-10 text-[180px] font-semibold leading-none text-white/6 xl:text-[240px]">NRL</div>

      <div class="relative z-10 flex h-full w-full flex-col justify-between p-10 text-white xl:p-14">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-sky-100/80">Portfolio Admin</p>
            <p class="mt-3 max-w-sm text-sm leading-7 text-blue-50/80 xl:text-base">
              Organize and control every important content block of your portfolio from one elegant dashboard.
            </p>
          </div>
          <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-right backdrop-blur-sm">
            <p class="text-[11px] uppercase tracking-[0.3em] text-blue-100/70">Status</p>
            <p class="mt-2 text-sm font-semibold text-white">Live Preview Ready</p>
          </div>
        </div>

        <div>
          <p class="max-w-xl text-4xl font-semibold leading-tight text-white xl:text-5xl">
            Manage your portfolio operations with a cleaner, faster, API-driven admin experience.
          </p>

          <div class="mt-10 grid gap-4 sm:grid-cols-2 xl:max-w-2xl">
            <div class="rounded-[24px] border border-white/15 bg-white/10 p-5 backdrop-blur-md">
              <p class="text-xs uppercase tracking-[0.3em] text-blue-100/70">Modules</p>
              <p class="mt-4 text-3xl font-semibold text-white">08</p>
              <p class="mt-2 text-sm text-blue-50/80">Profile, Projects, Skills, Experiences, Social Links, Tools, Messages</p>
            </div>

            <div class="rounded-[24px] border border-white/15 bg-white/10 p-5 backdrop-blur-md">
              <p class="text-xs uppercase tracking-[0.3em] text-blue-100/70">Architecture</p>
              <p class="mt-4 text-3xl font-semibold text-white">API</p>
              <p class="mt-2 text-sm text-blue-50/80">Admin panel communicates only with nrl-be backend services</p>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between gap-4 text-sm text-blue-50/70">
          <span>Responsive interface</span>
          <span>Secure authentication flow</span>
        </div>
      </div>
    </section>
  </div>
</div>
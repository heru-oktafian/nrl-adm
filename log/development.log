273:    <script>
274:    function editItem(itemJson) {
275:      const item = JSON.parse(itemJson);
276:      document.getElementById('edit-id').value = item.id;
277:      document.getElementById('modal-title').textContent = 'Edit ' + (item.title || item.name || item.platform || item.company || 'Item');
278:      
279:      let fieldsHtml = '';
280:      const resourceKey = '<%= @resource_key %>';
281:      
282:      switch(resourceKey) {
283:        case 'projects':
284:          fieldsHtml = `
285:            <div class="grid gap-4 md:grid-cols-2">
286:              <div>
287:                <label class="mb-2 block text-sm font-medium text-slate-700">Title</label>
288:                <input type="text" name="project[title]" value="${item.title || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
289:              </div>
290:              <div>
291:                <label class="mb-2 block text-sm font-medium text-slate-700">Tech Stack</label>
292:                <input type="text" name="project[tech_stack]" value="${item.tech_stack || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
293:              </div>
294:              <div class="md:col-span-2">
295:                <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>
296:                <textarea name="project[description]" rows="3" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">${item.description || ''}</textarea>
297:              </div>
298:              <div>
299:                <label class="mb-2 block text-sm font-medium text-slate-700">Image URL</label>
300:                <input type="text" name="project[image_url]" value="${item.image_url || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
301:              </div>
302:              <div>
303:                <label class="mb-2 block text-sm font-medium text-slate-700">URL</label>
304:                <input type="text" name="project[url]" value="${item.url || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
305:              </div>
306:            </div>
307:          `;
308:          break;
309:        case 'skills':
310:          fieldsHtml = `
311:            <div class="grid gap-4 md:grid-cols-2">
312:              <div>
313:                <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
314:                <input type="text" name="skill[name]" value="${item.name || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
315:              </div>
316:              <div>
317:                <label class="mb-2 block text-sm font-medium text-slate-700">Category</label>
318:                <select name="skill[category]" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
319:                  <option value="design" ${item.category === 'design' ? 'selected' : ''}>Design</option>
320:                  <option value="development" ${item.category === 'development' ? 'selected' : ''}>Development</option>
321:                  <option value="tools" ${item.category === 'tools' ? 'selected' : ''}>Tools</option>
322:                </select>
323:              </div>
324:              <div>
325:                <label class="mb-2 block text-sm font-medium text-slate-700">Level</label>
326:                <input type="number" name="skill[level]" value="${item.level || 0}" min="0" max="100" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
327:              </div>
328:            </div>
329:          `;
330:          break;
331:        case 'experiences':
332:          fieldsHtml = `
333:            <div class="grid gap-4 md:grid-cols-2">
334:              <div>
335:                <label class="mb-2 block text-sm font-medium text-slate-700">Company</label>
336:                <input type="text" name="experience[company]" value="${item.company || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
337:              </div>
338:              <div>
339:                <label class="mb-2 block text-sm font-medium text-slate-700">Position</label>
340:                <input type="text" name="experience[position]" value="${item.position || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
341:              </div>
342:              <div>
343:                <label class="mb-2 block text-sm font-medium text-slate-700">Start Date</label>
344:                <input type="text" name="experience[start_date]" value="${item.start_date || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
345:              </div>
346:              <div>
347:                <label class="mb-2 block text-sm font-medium text-slate-700">End Date</label>
348:                <input type="text" name="experience[end_date]" value="${item.end_date || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
349:              </div>
350:              <div class="md:col-span-2">
351:                <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>
352:                <textarea name="experience[description]" rows="3" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">${item.description || ''}</textarea>
353:              </div>
354:            </div>
355:          `;
356:          break;
357:        case 'social-links':
358:          fieldsHtml = `
359:            <div class="grid gap-4 md:grid-cols-2">
360:              <div>
361:                <label class="mb-2 block text-sm font-medium text-slate-700">Platform</label>
362:                <input type="text" name="social_link[platform]" value="${item.platform || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
363:              </div>
364:              <div>
365:                <label class="mb-2 block text-sm font-medium text-slate-700">URL</label>
366:                <input type="text" name="social_link[url]" value="${item.url || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
367:              </div>
368:              <div>
369:                <label class="mb-2 block text-sm font-medium text-slate-700">Icon</label>
370:                <input type="text" name="social_link[icon]" value="${item.icon || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
371:              </div>
372:            </div>
373:          `;
374:          break;
375:        case 'tools':
376:          fieldsHtml = `
377:            <div class="grid gap-4 md:grid-cols-2">
378:              <div>
379:                <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
380:                <input type="text" name="tool[name]" value="${item.name || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
381:              </div>
382:              <div>
383:                <label class="mb-2 block text-sm font-medium text-slate-700">Description</label>
384:                <input type="text" name="tool[description]" value="${item.description || ''}" class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
385:              </div>
386:            </div>
387:          `;
388:          break;
389:        default:
390:          fieldsHtml = '<p class="text-slate-500">Form tidak tersedia untuk modul ini.</p>';
391:      }
392:      
393:      document.getElementById('form-fields').innerHTML = fieldsHtml;
394:      document.getElementById('edit-modal').classList.remove('hidden');
395:    }
396:    
397:    function deleteItem(id, name) {
398:      document.getElementById('delete-text').textContent = 'Apakah anda yakin akan menghapus ' + name + '?';
399:      document.getElementById('delete-form').action = '/admin/<%= @resource_key %>/' + id;
400:      document.getElementById('delete-modal').classList.remove('hidden');
401:    }
402:    
403:    function closeModal() {
404:      document.getElementById('edit-modal').classList.add('hidden');
405:    }
406:    
407:    function closeDeleteModal() {
408:      document.getElementById('delete-modal').classList.add('hidden');
409:    }
410:    
411:    function showMessage(itemJson) {
412:      const item = JSON.parse(itemJson);
413:      const content = `
414:        <div class="grid gap-4 md:grid-cols-2">
415:          <div>
416:            <label class="mb-2 block text-sm font-medium text-slate-700">Name</label>
417:            <input type="text" value="${item.name || ''}" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm">
418:          </div>
419:          <div>
420:            <label class="mb-2 block text-sm font-medium text-slate-700">Email</label>
421:            <input type="text" value="${item.email || ''}" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm">
422:          </div>
423:          <div>
424:            <label class="mb-2 block text-sm font-medium text-slate-700">Phone</label>
425:            <input type="text" value="${item.phone || '-'}" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm">
426:          </div>
427:          <div>
428:            <label class="mb-2 block text-sm font-medium text-slate-700">Subject</label>
429:            <input type="text" value="${item.subject || ''}" readonly class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm">
430:          </div>
431:          <div class="md:col-span-2">
432:            <label class="mb-2 block text-sm font-medium text-slate-700">Message</label>
433:            <textarea readonly rows="5" class="w-full rounded-2xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm">${item.message || ''}</textarea>
434:          </div>
435:          <div class="md:col-span-2">
436:            <label class="mb-2 block text-sm font-medium text-slate-700">Status</label>
437:            <select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm">
438:              <option value="new" ${item.status === 'new' ? 'selected' : ''}>New</option>
439:              <option value="in_progress" ${item.status === 'in_progress' ? 'selected' : ''}>In Progress</option>
440:              <option value="done" ${item.status === 'done' ? 'selected' : ''}>Done</option>
441:            </select>
442:          </div>
443:        </div>
444:      `;
445:      document.getElementById('message-content').innerHTML = content;
446:      document.getElementById('message-modal').classList.remove('hidden');
447:    }
448:    
449:    function closeMessageModal() {
450:      document.getElementById('message-modal').classList.add('hidden');
451:    }
452:    
453:    // Close modals on backdrop click
454:    document.getElementById('edit-modal').addEventListener('click', function(e) {
455:      if (e.target === this) closeModal();
456:    });
457:    document.getElementById('delete-modal').addEventListener('click', function(e) {
458:      if (e.target === this) closeDeleteModal();
459:    });
460:    document.getElementById('message-modal').addEventListener('click', function(e) {
461:      if (e.target === this) closeMessageModal();
462:    });
463:    </script>
  
